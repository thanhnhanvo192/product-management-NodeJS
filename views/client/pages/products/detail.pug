extends ../../layouts/default.pug

block main 
  .container.my-3 
    .row
      .col-12 
        if (product.title)
          h1(class="mb-4") #{product.title}

        if (product.price)
          div(class="mb-4") Giá: #{product.price}$
        
        if (product.discountPercentage)
          div(class="mb-4") Giảm giá: #{product.discountPercentage}%

        if (product.stock)
          div(class="mb-4") Số lượng: #{product.stock}
        
        if (product.thumbnail)
          img(src=product.thumbnail, alt=product.title, class="img-fluid" width="100px")
        
        if (product.position)
          div(class="mb-4") Vị trí: #{product.position}

        if (product.description)
          div(class="mb-4") Mô tả: #{product.description}